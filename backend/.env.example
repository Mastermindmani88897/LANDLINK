# LandLink Backend Environment Variables for Render / Production
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/landlink?retryWrites=true&w=majority
JWT_SECRET=SUPER_SECRET_LANDLINK_AI_KEY_CHANGE_THIS_IN_PRODUCTION
GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-landlink-app.vercel.app
