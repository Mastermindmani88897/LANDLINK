# LandLink Frontend Environment Variables
# In production on Vercel, set VITE_API_URL to your Render backend API URL.
# Example: https://landlink-backend.onrender.com/api/v1
VITE_API_URL=http://127.0.0.1:5000/api/v1

# Google OAuth 2.0 — get Client ID from Google Cloud Console → APIs & Services → Credentials
# In production on Vercel, set this as an Environment Variable in the Vercel dashboard.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
